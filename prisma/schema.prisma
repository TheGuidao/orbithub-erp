// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql" 
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

// ==========================================
// NOVO MÓDULO: CARGOS E PERMISSÕES (RBAC)
// ==========================================

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  color       String   @default("blue")
  permissions Json     
  
  users       User[]
}

// ==========================================
// USUÁRIOS
// ==========================================

model User {
  id            Int           @id @default(autoincrement())
  name          String
  username      String?       @unique
  email         String?       @unique // Opcional para não quebrar banco antigo
  password      String?
  active        Boolean       @default(true)
  
  // Vínculo com o Cargo Dinâmico
  roleId        Int?
  role          Role?         @relation(fields: [roleId], references: [id])
  
  transactions  Transaction[]
  vehicleLogs   VehicleLog[]
  serviceOrders ServiceOrder[]
  comments      Comment[]
}

// ==========================================
// CATEGORIAS DINÂMICAS
// ==========================================

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique 
  type          String        @default("EQUIPAMENTO") 
  
  subcategories Subcategory[]
}

model Subcategory {
  id            Int           @id @default(autoincrement())
  name          String        
  categoryId    Int
  
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  materials     Material[]
}

model Material {
  id            Int           @id @default(autoincrement())
  name          String
  category      String?       
  subcategoryId Int?
  brand         String?       
  minStock      Int           @default(5)
  currentStock  Int           @default(0)
  
  subcategory   Subcategory?  @relation(fields: [subcategoryId], references: [id])
  transactions  Transaction[]
  serviceOrders ServiceOrderMaterial[]
}

model Transaction {
  id              Int       @id @default(autoincrement())
  materialId      Int
  userId          Int?      
  type            String
  quantity        Int
  relatedOutbound Int?
  notes           String?   
  clientName      String?   
  assinatura      Boolean   @default(false) 
  signatureData   String?   
  createdAt       DateTime  @default(now())

  material Material @relation(fields: [materialId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])
}

model Vehicle {
  id             Int                  @id @default(autoincrement())
  model          String
  plate          String               @unique
  currentKm      Int
  
  logs           VehicleLog[]
  maintenances   VehicleMaintenance[] 
  serviceOrders  ServiceOrder[]
}

model VehicleLog {
  id            Int      @id @default(autoincrement())
  vehicleId     Int
  userId        Int
  date          DateTime @default(now())
  startKm       Int
  endKm         Int?
  cleanState    String
  notes         String?
  assinatura    Boolean  @default(false) 
  signatureData String?  

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model VehicleMaintenance {
  id             Int      @id @default(autoincrement())
  vehicleId      Int
  type           String   
  date           DateTime @default(now())
  performedKm    Int      
  nextRevisionKm Int?     
  description    String?  
  cost           Float?   

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

// ==========================================
// RMA
// ==========================================

model RmaEquipment {
  id              Int      @id @default(autoincrement())
  equipmentName   String   
  clientName      String?  
  serialNumber    String?  
  problemDetected String   
  status          String   @default("EM_ANALISE") 
  isFromStock     Boolean  @default(false) 
  materialId      Int?     
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// OBRAS E AGENDAS
// ==========================================

model ServiceOrder {
  id              Int       @id @default(autoincrement())
  title           String    
  description     String?   
  address         String?   
  date            DateTime? 
  startTime       String?   
  endTime         String?   
  status          String    @default("AGENDADO") 
  clientSignature String?   
  clientName      String?   
  clientCpf       String?   
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  team            User[]    
  vehicles        Vehicle[] 
  materials       ServiceOrderMaterial[] 
  comments        Comment[]              
  checklist       ChecklistItem[]        
  attachments     Attachment[]           
}

model ServiceOrderMaterial {
  id             Int          @id @default(autoincrement())
  quantity       Int          
  serviceOrderId Int
  materialId     Int
  
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  material       Material     @relation(fields: [materialId], references: [id])
}

model Comment {
  id             Int          @id @default(autoincrement())
  content        String
  createdAt      DateTime     @default(now())
  serviceOrderId Int
  userId         Int
  
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
}

model ChecklistItem {
  id             Int          @id @default(autoincrement())
  task           String
  isDone         Boolean      @default(false)
  serviceOrderId Int
  
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
}

model Attachment {
  id             Int          @id @default(autoincrement())
  fileName       String
  fileUrl        String       
  serviceOrderId Int
  createdAt      DateTime     @default(now())
  
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
}